generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

enum SellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  CANCELED
  EXPIRED
}

enum ProductDeactivationReason {
  NONE
  SELLER
  ADMIN
  SUBSCRIPTION_INACTIVE
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ReviewStatus {
  PUBLISHED
  PENDING
  REJECTED
}

enum ReviewReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

model User {
  id                       String   @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String   @unique
  passwordHash             String
  role                     UserRole @default(CUSTOMER)
  storeName                String?
  emailVerified            Boolean  @default(false)
  stripeAccountId          String?  @unique
  stripeOnboardingComplete Boolean  @default(false)
  stripeChargesEnabled     Boolean  @default(false)
  stripePayoutsEnabled     Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  store               Store?
  buyerConversations  Conversation[] @relation("ConversationBuyer")
  sellerConversations Conversation[] @relation("ConversationSeller")
  sentMessages        Message[]
  notifications       Notification[]
  orders              Order[]
  reviews             Review[]
  reviewReports       ReviewReport[]
}

model Store {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  logo        String?
  banner      String?
  country     String
  city        String
  contactEmail String
  phone       String?
  currency    String  @default("EUR")
  language    String  @default("fr")
  status      SellerStatus @default(PENDING)
  stripeCustomerId String? @unique

  ownerId String @unique
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  products      Product[]
  conversations Conversation[]
  subscription  SellerSubscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id             String        @id @default(cuid())
  name           String
  slug           String
  description    String
  price          Decimal       @db.Decimal(12, 2)
  compareAtPrice Decimal?      @db.Decimal(12, 2)
  colors         String[]      @default([])
  sizes          String[]      @default([])
  currency       String        @default("EUR")
  category       String
  stock          Int           @default(1)
  condition      String
  images         String[]
  status         ProductStatus @default(PUBLISHED)
  deactivationReason ProductDeactivationReason @default(NONE)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations Conversation[]
  orderItems    OrderItem[]
  reviews       Review[]

  @@unique([storeId, slug])
  @@index([storeId, status])
  @@index([category])
}

model SellerSubscription {
  id                   String             @id @default(cuid())
  storeId              String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String
  plan                 String
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Conversation {
  id            String   @id @default(cuid())
  buyerId       String
  sellerId      String
  storeId       String
  productId     String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  buyer    User      @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("ConversationSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([buyerId, productId])
  @@index([sellerId, lastMessageAt])
  @@index([buyerId, lastMessageAt])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String    @db.VarChar(2000)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Order {
  id                       String      @id @default(cuid())
  buyerId                  String
  status                   OrderStatus @default(PENDING)
  currency                 String      @default("EUR")
  total                    Decimal     @db.Decimal(12, 2)
  paidAt                   DateTime?
  checkoutRequestId        String
  stripeCheckoutSessionId  String?     @unique
  stripeCheckoutUrl        String?
  stripePaymentIntentId    String?     @unique
  stripeConnectedAccountId String?
  platformFeeAmount        Int?
  sellerAmount             Int?
  deliveredAt              DateTime?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  buyer User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@unique([buyerId, checkoutRequestId])
  @@index([buyerId, status, createdAt])
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  review  Review?

  @@unique([orderId, productId])
  @@index([productId])
}

model Review {
  id          String       @id @default(cuid())
  productId   String
  authorId    String
  orderItemId String       @unique
  rating      Int
  title       String?      @db.VarChar(120)
  body        String       @db.VarChar(2000)
  status      ReviewStatus @default(PUBLISHED)
  sellerReply String?      @db.VarChar(1500)
  repliedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  orderItem OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  reports   ReviewReport[]

  @@unique([authorId, productId])
  @@index([productId, status, createdAt])
}

model ReviewReport {
  id         String             @id @default(cuid())
  reviewId   String
  reporterId String
  reason     String             @db.VarChar(500)
  status     ReviewReportStatus @default(OPEN)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reviewId, reporterId])
  @@index([status, createdAt])
}
