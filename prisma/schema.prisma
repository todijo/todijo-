generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

model User {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(CUSTOMER)
  storeName     String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store         Store?
  buyerConversations Conversation[] @relation("ConversationBuyer")
  sellerConversations Conversation[] @relation("ConversationSeller")
  sentMessages       Message[]
  notifications      Notification[]
}

model Store {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  logo        String?
  banner      String?
  country     String
  city        String
  currency    String    @default("EUR")
  language    String    @default("fr")

  ownerId     String    @unique
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  products    Product[]
  conversations Conversation[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String
  description String
  price       Decimal       @db.Decimal(12, 2)
  compareAtPrice Decimal?    @db.Decimal(12, 2)
  colors      String[]      @default([])
  sizes       String[]      @default([])
  currency    String        @default("EUR")
  category    String
  stock       Int           @default(1)
  condition   String
  images      String[]
  status      ProductStatus @default(PUBLISHED)

  storeId     String
  store       Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  conversations Conversation[]

  @@unique([storeId, slug])
  @@index([storeId, status])
  @@index([category])
}

model Conversation {
  id          String   @id @default(cuid())
  buyerId     String
  sellerId    String
  storeId     String
  productId   String
  lastMessageAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  buyer       User     @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller      User     @relation("ConversationSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@unique([buyerId, productId])
  @@index([sellerId, lastMessageAt])
  @@index([buyerId, lastMessageAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @db.VarChar(2000)
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}
